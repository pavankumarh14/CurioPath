# ── REQUIRED ──────────────────────────────────────────────────────────────────
# LearnSwarm requires a real Groq API key — there is no mock mode.
# Get your free key at https://console.groq.com (takes 30 seconds).
# Each candidate should use their OWN key — do not share across teams.
GROQ_API_KEY=your_groq_key_here

# ── OPTIONAL ──────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_ORIGIN=http://localhost:5173
NODE_ENV=development
